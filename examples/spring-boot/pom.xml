<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-parent</artifactId>
    <version>3.4.0</version>
    <relativePath/>
  </parent>

  <groupId>dev.invoicekit.examples</groupId>
  <artifactId>invoicekit-example-spring-boot</artifactId>
  <version>0.0.0-SNAPSHOT</version>
  <packaging>jar</packaging>

  <name>InvoiceKit Spring Boot Demo</name>
  <description>T-1403 reference demo: canonicalises German XRechnung via the InvoiceKit Java SDK.</description>

  <licenses>
    <license>
      <name>Apache License, Version 2.0</name>
      <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
      <distribution>repo</distribution>
    </license>
  </licenses>

  <properties>
    <java.version>22</java.version>
    <maven.compiler.release>${java.version}</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <ffm.argLine>--enable-native-access=ALL-UNNAMED</ffm.argLine>
  </properties>

  <dependencies>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-web</artifactId>
    </dependency>
    <dependency>
      <groupId>dev.invoicekit</groupId>
      <artifactId>invoicekit-java</artifactId>
      <version>0.0.0-SNAPSHOT</version>
    </dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-test</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
      </plugin>
      <!-- Surefire default ignores *IT.java; include them so the
           single SmokeIT runs in the default test phase. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <configuration>
          <includes>
            <include>**/*Test.java</include>
            <include>**/*IT.java</include>
          </includes>
          <!-- Java 22 FFM stabilised but System.loadLibrary still
               requires the native access flag. Without it the
               native bridge throws and the demo falls back to a
               REST sidecar that is not running in tests. -->
          <argLine>${ffm.argLine}</argLine>
          <environmentVariables>
            <INVOICEKIT_FFI_LIB>${env.INVOICEKIT_FFI_LIB}</INVOICEKIT_FFI_LIB>
          </environmentVariables>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
