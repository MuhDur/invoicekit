{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommercialDocument",
  "description": "Jurisdiction-agnostic commercial invoice or credit note semantics.",
  "type": "object",
  "properties": {
    "schema_version": {
      "description": "Schema version.",
      "$ref": "#/$defs/SchemaVersion",
      "default": "1.0"
    },
    "id": {
      "description": "Stable document identifier.",
      "type": "string"
    },
    "document_type": {
      "description": "Document type.",
      "$ref": "#/$defs/DocumentType"
    },
    "issue_date": {
      "description": "Issue date.",
      "type": "string"
    },
    "tax_point_date": {
      "description": "Optional tax point date.",
      "type": [
        "string",
        "null"
      ]
    },
    "due_date": {
      "description": "Optional due date.",
      "type": [
        "string",
        "null"
      ]
    },
    "invoice_period": {
      "description": "Optional invoice billing period (EN 16931 BG-14).",
      "anyOf": [
        {
          "$ref": "#/$defs/InvoicePeriod"
        },
        {
          "type": "null"
        }
      ]
    },
    "delivery_date": {
      "description": "Optional actual delivery date (EN 16931 BT-72).",
      "type": [
        "string",
        "null"
      ]
    },
    "document_number": {
      "description": "Document number.",
      "type": "string"
    },
    "currency": {
      "description": "Document currency.",
      "type": "string"
    },
    "supplier": {
      "description": "Supplier party.",
      "$ref": "#/$defs/Party"
    },
    "customer": {
      "description": "Customer party.",
      "$ref": "#/$defs/Party"
    },
    "payee": {
      "description": "Optional payee party.",
      "anyOf": [
        {
          "$ref": "#/$defs/Party"
        },
        {
          "type": "null"
        }
      ]
    },
    "payment_terms": {
      "description": "Optional payment terms.",
      "anyOf": [
        {
          "$ref": "#/$defs/PaymentTerms"
        },
        {
          "type": "null"
        }
      ]
    },
    "payment_instructions": {
      "description": "Payment instructions.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/PaymentInstruction"
      },
      "default": []
    },
    "lines": {
      "description": "Document lines.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/DocumentLine"
      }
    },
    "tax_summary": {
      "description": "Tax summaries.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/TaxCategorySummary"
      },
      "default": []
    },
    "monetary_total": {
      "description": "Monetary total.",
      "$ref": "#/$defs/MonetaryTotal"
    },
    "attachments": {
      "description": "Content-addressed attachments.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/Attachment"
      }
    },
    "references": {
      "description": "Commercial document references.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/DocumentReference"
      }
    },
    "notes": {
      "description": "Human-readable notes.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/LocalizedString"
      }
    },
    "extensions": {
      "description": "Jurisdiction extension envelopes.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/JurisdictionExtension"
      },
      "default": []
    },
    "allowance_charges": {
      "description": "Document-level allowances (EN 16931 BG-20) and charges (BG-21).",
      "type": "array",
      "items": {
        "$ref": "#/$defs/DocumentAllowanceCharge"
      }
    },
    "deliver_to": {
      "description": "Optional deliver-to information (EN 16931 BG-13 / BG-15).",
      "anyOf": [
        {
          "$ref": "#/$defs/DeliverToParty"
        },
        {
          "type": "null"
        }
      ]
    },
    "meta": {
      "description": "Operational metadata.",
      "$ref": "#/$defs/DocumentMeta"
    }
  },
  "required": [
    "id",
    "document_type",
    "issue_date",
    "document_number",
    "currency",
    "supplier",
    "customer",
    "lines",
    "monetary_total",
    "meta"
  ],
  "$defs": {
    "SchemaVersion": {
      "description": "Canonical schema version carried by every serialized document.",
      "oneOf": [
        {
          "description": "Initial public IR version.",
          "type": "string",
          "const": "1.0"
        }
      ]
    },
    "DocumentType": {
      "description": "Top-level document type.",
      "oneOf": [
        {
          "description": "Commercial invoice.",
          "type": "string",
          "const": "invoice"
        },
        {
          "description": "Credit note.",
          "type": "string",
          "const": "credit_note"
        },
        {
          "description": "Debit note.",
          "type": "string",
          "const": "debit_note"
        },
        {
          "description": "Pro forma invoice.",
          "type": "string",
          "const": "pro_forma"
        },
        {
          "description": "Self-billed invoice.",
          "type": "string",
          "const": "self_billed"
        }
      ]
    },
    "InvoicePeriod": {
      "description": "Invoice billing period (EN 16931 BG-14).\n\n The date range the invoice covers (e.g. a periodic or summary invoice). At\n least one of `start_date` (BT-73) or `end_date` (BT-74) must be present when\n the group is used.",
      "type": "object",
      "properties": {
        "start_date": {
          "description": "Period start date (BT-73).",
          "type": [
            "string",
            "null"
          ]
        },
        "end_date": {
          "description": "Period end date (BT-74).",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Party": {
      "description": "Commercial party.",
      "type": "object",
      "properties": {
        "id": {
          "description": "Optional stable party identifier.",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "Legal or trading name.",
          "type": "string"
        },
        "tax_ids": {
          "description": "Tax identifiers carried by the party.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/PartyTaxId"
          }
        },
        "address": {
          "description": "Postal address.",
          "$ref": "#/$defs/PostalAddress"
        },
        "contact": {
          "description": "Optional contact details.",
          "anyOf": [
            {
              "$ref": "#/$defs/Contact"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name",
        "address"
      ]
    },
    "PartyTaxId": {
      "description": "Party tax identifier.",
      "type": "object",
      "properties": {
        "scheme": {
          "description": "Identifier scheme, such as `vat`.",
          "type": "string"
        },
        "value": {
          "description": "Identifier value.",
          "type": "string"
        }
      },
      "required": [
        "scheme",
        "value"
      ]
    },
    "PostalAddress": {
      "description": "Postal address for a supplier, customer, payee, or other party.",
      "type": "object",
      "properties": {
        "lines": {
          "description": "Address lines in display order.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "city": {
          "description": "Locality or city.",
          "type": "string"
        },
        "subdivision": {
          "description": "Optional subdivision, state, province, or region.",
          "type": [
            "string",
            "null"
          ]
        },
        "postal_code": {
          "description": "Postal code.",
          "type": "string"
        },
        "country": {
          "description": "Country code.",
          "type": "string"
        }
      },
      "required": [
        "lines",
        "city",
        "postal_code",
        "country"
      ]
    },
    "Contact": {
      "description": "Contact details for a party.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Optional contact name.",
          "type": [
            "string",
            "null"
          ]
        },
        "email": {
          "description": "Optional email address.",
          "type": [
            "string",
            "null"
          ]
        },
        "phone": {
          "description": "Optional telephone number.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "PaymentTerms": {
      "description": "Payment terms attached to the document.",
      "type": "object",
      "properties": {
        "description": {
          "description": "Human-readable payment terms.",
          "type": "string"
        },
        "due_date": {
          "description": "Optional due date stated in the terms.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "description"
      ]
    },
    "PaymentInstruction": {
      "description": "Payment instruction.",
      "type": "object",
      "properties": {
        "kind": {
          "description": "Instruction kind.",
          "$ref": "#/$defs/PaymentInstructionKind"
        },
        "account": {
          "description": "Optional account or payment address.",
          "type": [
            "string",
            "null"
          ]
        },
        "reference": {
          "description": "Optional payment reference.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "kind"
      ]
    },
    "PaymentInstructionKind": {
      "description": "Payment rail or instruction kind.",
      "oneOf": [
        {
          "description": "SEPA credit transfer.",
          "type": "string",
          "const": "sepa"
        },
        {
          "description": "IBAN or BIC transfer.",
          "type": "string",
          "const": "iban_bic"
        },
        {
          "description": "Swiss QR payment.",
          "type": "string",
          "const": "swiss_qr"
        },
        {
          "description": "EPC QR payment.",
          "type": "string",
          "const": "epc_qr"
        },
        {
          "description": "Saudi ZATCA QR payload.",
          "type": "string",
          "const": "zatca_qr"
        },
        {
          "description": "Other instruction kind described by the `account` or `reference`.",
          "type": "string",
          "const": "other"
        }
      ]
    },
    "DocumentLine": {
      "description": "Document line.",
      "type": "object",
      "properties": {
        "description": {
          "description": "Line description.",
          "type": "string"
        },
        "id": {
          "description": "Line identifier.",
          "type": "string"
        },
        "quantity": {
          "description": "Invoiced quantity.",
          "type": "string"
        },
        "unit_code": {
          "description": "Optional unit code.",
          "type": [
            "string",
            "null"
          ]
        },
        "unit_price": {
          "description": "Unit price amount.",
          "type": "string"
        },
        "line_extension_amount": {
          "description": "Line extension amount.",
          "type": "string"
        },
        "tax_category": {
          "description": "Optional tax category code.",
          "type": [
            "string",
            "null"
          ]
        },
        "classifications": {
          "description": "Commodity/service classifications (EN 16931 BG-? / BT-158; national\n schemes such as HSN/SAC, NCM, `ClaveProdServ`). Empty when unclassified.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ItemClassification"
          }
        },
        "extensions": {
          "description": "Line-level jurisdiction extensions.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/JurisdictionExtension"
          }
        }
      },
      "required": [
        "id",
        "description",
        "quantity",
        "unit_price",
        "line_extension_amount"
      ]
    },
    "ItemClassification": {
      "description": "Commodity or service classification of a line item.\n\n Models EN 16931 BT-158 *Item classification identifier* together with its\n scheme identifier (BT-158-1) and optional scheme version (BT-158-2). The\n `scheme_id` is an open list (e.g. UNTDID 7143 codes such as `HS`/`SRV`, or a\n national scheme name like `HSN`, `SAC`, `NCM`, `ClaveProdServ`, `UNSPSC`),\n mirroring the open `scheme` on [`PartyTaxId`]. A line may carry several\n classifications, so consumers select the scheme they need (a UBL/CII\n serializer emits all of them; a national report picks its own scheme).",
      "type": "object",
      "properties": {
        "code": {
          "description": "Classification code value (EN 16931 BT-158).",
          "type": "string"
        },
        "scheme_id": {
          "description": "Scheme/list identifier the code belongs to (EN 16931 BT-158-1 `listID`).",
          "type": "string"
        },
        "scheme_version": {
          "description": "Optional scheme version (EN 16931 BT-158-2 `listVersionID`).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "code",
        "scheme_id"
      ]
    },
    "JurisdictionExtension": {
      "description": "Polymorphic jurisdiction or profile extension payload.\n\n # URN scheme casing (ebaq)\n\n RFC 8141 declares the URN scheme name case-insensitive. Real producers\n in the wild (notably some legacy XML exporters) emit `URN:` or `Urn:`.\n Both [`JurisdictionExtension::new`] and the [`Deserialize`] implementation\n accept any casing of the scheme prefix and normalise it to the canonical\n lowercase `urn:` so equality checks remain stable.\n\n The namespace identifier and namespace-specific string are preserved\n verbatim. Rule-pack URN registries stay as shipped — Peppol's UNCL1001\n codes are lowercase by definition, ZUGFeRD profile URNs are mixed case,\n and changing those bytes would break canonical signing payloads.",
      "type": "object",
      "properties": {
        "urn": {
          "description": "Uniform resource name for the extension schema (canonical lowercase\n `urn:` prefix).",
          "type": "string"
        },
        "payload": {
          "description": "Extension payload validated by the country or profile registry."
        }
      },
      "required": [
        "urn",
        "payload"
      ]
    },
    "TaxCategorySummary": {
      "description": "Tax category summary.",
      "type": "object",
      "properties": {
        "category_code": {
          "description": "Tax category code.",
          "type": "string"
        },
        "taxable_amount": {
          "description": "Taxable amount.",
          "type": "string"
        },
        "tax_amount": {
          "description": "Tax amount.",
          "type": "string"
        },
        "tax_rate": {
          "description": "Optional tax rate.",
          "type": [
            "string",
            "null"
          ]
        },
        "exemption_reason": {
          "description": "Optional VAT exemption reason text (EN 16931 BT-120), for an exempt /\n zero-rated / reverse-charge category. Carried verbatim from the producer.",
          "type": [
            "string",
            "null"
          ]
        },
        "exemption_reason_code": {
          "description": "Optional VAT exemption reason code (EN 16931 BT-121), from a controlled\n list such as CEF `VATEX` or IT `Natura`. Carried verbatim from the\n producer — InvoiceKit serializes whatever code is supplied and does not\n invent one (the national code-list mapping is a separate concern).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "category_code",
        "taxable_amount",
        "tax_amount"
      ]
    },
    "MonetaryTotal": {
      "description": "Document monetary totals.",
      "type": "object",
      "properties": {
        "line_extension_amount": {
          "description": "Sum of line extension amounts.",
          "type": "string"
        },
        "tax_exclusive_amount": {
          "description": "Tax-exclusive amount.",
          "type": "string"
        },
        "tax_inclusive_amount": {
          "description": "Tax-inclusive amount.",
          "type": "string"
        },
        "allowance_total_amount": {
          "description": "Optional allowance total.",
          "type": [
            "string",
            "null"
          ]
        },
        "charge_total_amount": {
          "description": "Optional charge total.",
          "type": [
            "string",
            "null"
          ]
        },
        "prepaid_amount": {
          "description": "Optional prepaid amount.",
          "type": [
            "string",
            "null"
          ]
        },
        "payable_amount": {
          "description": "Payable amount.",
          "type": "string"
        }
      },
      "required": [
        "line_extension_amount",
        "tax_exclusive_amount",
        "tax_inclusive_amount",
        "payable_amount"
      ]
    },
    "Attachment": {
      "description": "Content-addressed attachment reference.",
      "type": "object",
      "properties": {
        "kind": {
          "description": "Attachment role or semantic type.",
          "type": "string"
        },
        "digest": {
          "description": "Content digest.",
          "type": "string"
        },
        "media_type": {
          "description": "Media type.",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "digest",
        "media_type"
      ]
    },
    "DocumentReference": {
      "description": "Reference to another commercial document.",
      "type": "object",
      "properties": {
        "kind": {
          "description": "Reference type, such as purchase order.",
          "type": "string"
        },
        "id": {
          "description": "Referenced identifier.",
          "type": "string"
        },
        "issue_date": {
          "description": "Optional referenced issue date.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "kind",
        "id"
      ]
    },
    "LocalizedString": {
      "description": "Localized human text.",
      "type": "object",
      "properties": {
        "language": {
          "description": "BCP 47 language tag.",
          "type": "string"
        },
        "text": {
          "description": "Localized text value.",
          "type": "string"
        }
      },
      "required": [
        "language",
        "text"
      ]
    },
    "DocumentAllowanceCharge": {
      "description": "Document-level allowance (EN 16931 BG-20) or charge (BG-21).\n\n Both groups share an identical structure distinguished by `is_charge`; only\n the business-term numbers differ (allowance BT-92..98 / charge BT-99..105).\n The detail is carried verbatim from the producer — InvoiceKit serializes the\n supplied amounts/codes faithfully and does not recompute or reconcile them\n against the document totals (that is the reference validator's responsibility).",
      "type": "object",
      "properties": {
        "is_charge": {
          "description": "`true` = charge (BG-21), `false` = allowance (BG-20).",
          "type": "boolean"
        },
        "amount": {
          "description": "Allowance/charge amount (BT-92 / BT-99).",
          "type": "string"
        },
        "base_amount": {
          "description": "Optional base amount the percentage applies to (BT-93 / BT-100).",
          "type": [
            "string",
            "null"
          ]
        },
        "percentage": {
          "description": "Optional percentage of the base amount (BT-94 / BT-101).",
          "type": [
            "string",
            "null"
          ]
        },
        "tax_category": {
          "description": "Optional VAT category code for the allowance/charge (BT-95 / BT-102).",
          "type": [
            "string",
            "null"
          ]
        },
        "tax_rate": {
          "description": "Optional VAT rate (BT-96 / BT-103).",
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "description": "Optional reason text (BT-97 / BT-104).",
          "type": [
            "string",
            "null"
          ]
        },
        "reason_code": {
          "description": "Optional reason code (BT-98 / BT-105), from UNCL 5189 (allowances) or\n UNCL 7161 (charges); carried verbatim.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "is_charge",
        "amount"
      ]
    },
    "DeliverToParty": {
      "description": "Deliver-to information (EN 16931 BG-13): where the goods or services are\n delivered, when that differs from the buyer.\n\n The actual delivery date (BT-72) is the separate top-level `delivery_date`\n field; this group carries the deliver-to party name (BT-70), location\n identifier (BT-71), and address (EN 16931 BG-15).",
      "type": "object",
      "properties": {
        "name": {
          "description": "Deliver-to party name (BT-70).",
          "type": [
            "string",
            "null"
          ]
        },
        "location_id": {
          "description": "Deliver-to location identifier (BT-71).",
          "type": [
            "string",
            "null"
          ]
        },
        "address": {
          "description": "Deliver-to address (EN 16931 BG-15).",
          "anyOf": [
            {
              "$ref": "#/$defs/PostalAddress"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "DocumentMeta": {
      "description": "Operational metadata for a document.",
      "type": "object",
      "properties": {
        "tenant_id": {
          "description": "Tenant identifier.",
          "type": "string"
        },
        "trace_id": {
          "description": "Trace identifier for audit correlation.",
          "type": "string"
        },
        "source_system": {
          "description": "Optional source system.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "tenant_id",
        "trace_id"
      ]
    }
  }
}
