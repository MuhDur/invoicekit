<odoo>
  <record id="res_config_settings_view_form_invoicekit" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.invoicekit</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="account.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//block[@id='invoice_settings']" position="after">
        <block title="InvoiceKit" id="invoicekit_settings">
          <setting>
            <field name="invoicekit_sidecar_url"/>
            <div class="text-muted">
              Base URL of the InvoiceKit sidecar that owns transmission and evidence-bundle storage.
            </div>
          </setting>
          <setting>
            <field name="invoicekit_api_key" password="True"/>
            <div class="text-muted">
              Optional bearer token sent with sidecar requests.
            </div>
          </setting>
        </block>
      </xpath>
    </field>
  </record>
</odoo>
