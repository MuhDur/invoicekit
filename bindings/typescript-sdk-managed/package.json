{
  "name": "@invoicekit/managed",
  "version": "0.0.0",
  "description": "Typed REST client for the InvoiceKit managed-API gateway. Wraps audit-log queries, reconcile, and SSE event streams.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/MuhDur/invoicekit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MuhDur/invoicekit.git",
    "directory": "bindings/typescript-sdk-managed"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "check": "bunx tsc --noEmit -p tsconfig.json",
    "test": "bun test tests/client.test.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "invoice",
    "e-invoicing",
    "rest",
    "client",
    "managed-api",
    "audit-log"
  ]
}
