{
  "name": "@invoicekit/render",
  "version": "0.0.0",
  "description": "TypeScript helpers for rendering CommercialDocument values to HTML/PDF via the InvoiceKit wasm engine.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/MuhDur/invoicekit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MuhDur/invoicekit.git",
    "directory": "bindings/typescript-sdk-render"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "check": "bunx tsc --noEmit -p tsconfig.json",
    "test": "bun test tests/render.test.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "invoice",
    "e-invoicing",
    "render",
    "html",
    "pdf",
    "wasm"
  ]
}
